{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f .claude/state/session.md ]; then echo '--- SESSION STATE ---'; cat .claude/state/session.md; echo '--- END SESSION STATE ---'; fi",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Task",
      "Skill(startup)",
      "Skill(orient)"
    ]
  }
}
